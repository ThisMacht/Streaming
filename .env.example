# Repository
REPO_NAME=accelerate
REPO_URL=https://github.com/huggingface/accelerate.git
REPO_LOCAL_PATH=data/raw/accelerate

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_NODES=cpg.nodes.v1
KAFKA_TOPIC_EDGES=cpg.edges.v1
KAFKA_TOPIC_METADATA=cpg.metadata.v1
KAFKA_TOPIC_ERRORS=cpg.errors.v1

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=cpg_lab
MONGODB_COLLECTION_METADATA=source_metadata

# Spark
SPARK_CHECKPOINT_LOCATION=outputs/checkpoints/mongodb_metadata
